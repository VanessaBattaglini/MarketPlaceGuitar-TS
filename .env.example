# Configuración de la Aplicación GuitarLA
# Copia este archivo a .env y actualiza los valores según tu entorno

# ============================================================================
# API BASE URL
# ============================================================================
# URL base para las peticiones API (cuando esté disponible el backend)
# En desarrollo: http://localhost:3000/api
# En producción: https://api.guitarla.com
VITE_API_BASE_URL=http://localhost:3000/api

# ============================================================================
# LOGGING
# ============================================================================
# Nivel de logging: DEBUG, INFO, WARN, ERROR
# En desarrollo: DEBUG (muestra todos los logs)
# En producción: ERROR (solo errores)
VITE_LOG_LEVEL=DEBUG

# ============================================================================
# CARRITO
# ============================================================================
# Cantidad máxima de items iguales permitidos en el carrito
VITE_CART_MAX_ITEMS=5

# Cantidad mínima de items permitidos en el carrito
VITE_CART_MIN_ITEMS=1

# Clave de localStorage donde se persiste el carrito
VITE_CART_STORAGE_KEY=cart

# ============================================================================
# FEATURES
# ============================================================================
# Habilitar notificaciones toast
VITE_ENABLE_NOTIFICATIONS=true

# Habilitar dark mode
VITE_ENABLE_DARK_MODE=false

# Habilitar analytics
VITE_ENABLE_ANALYTICS=false

# ============================================================================
# TIMEOUT Y RETRY
# ============================================================================
# Timeout en milisegundos para peticiones HTTP
VITE_REQUEST_TIMEOUT=30000

# Número de reintentos automáticos para peticiones fallidas
VITE_MAX_RETRIES=3

# ============================================================================
# DEBUGGING
# ============================================================================
# Habilitar logs detallados en console
VITE_DEBUG_MODE=true

# Habilitar Redux DevTools para debugging
VITE_DEBUG_REDUX_DEVTOOLS=true
